___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const injectScript = require('injectScript');
const encodeUriComponent = require('encodeUriComponent');
const log = require('logToConsole');

const integrationId = data.integrationId;
const scriptUrl = 'https://onboard.triptease.io/bootstrap.js?integrationId=' + encodeUriComponent(integrationId);

log('Triptease: Loading bootstrap script with integrationId:', integrationId);

injectScript(scriptUrl, data.gtmOnSuccess, data.gtmOnFailure, 'triptease-bootstrap');


