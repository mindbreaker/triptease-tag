    mock('injectScript', function(url, onSuccess, onFailure, cacheToken) {
      onSuccess();
    });

    runCode(mockData);
    assertApi('gtmOnSuccess').wasCalled();
- name: Tag fails gracefully
  code: |-
    const mockData = {
      integrationId: '01KFDG8GYR8V0RYNA7E4H2Z0EB'
    };

    mock('injectScript', function(url, onSuccess, onFailure, cacheToken) {
      onFailure();
    });

    runCode(mockData);
    assertApi('gtmOnFailure').wasCalled();


